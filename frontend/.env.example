# Copy this file to `.env` and fill in the values to enable Logto sign-in
# locally. Leaving any value empty disables auth — the UI shows
# "Auth not configured" and API calls go out without a bearer (the
# backend then 401s, which the pages render as "Sign in required").

# The Logto instance URL, e.g. http://localhost:3001 for a local dev instance.
NUXT_LOGTO_ENDPOINT=

# The application ID Logto issues when you register Sabro's frontend as a
# "Traditional Web" application.
NUXT_LOGTO_APP_ID=

# The application secret for the same Logto app. Server-side only —
# never exposed to the browser.
NUXT_LOGTO_APP_SECRET=

# Any random string used to encrypt the Logto session cookie.
# Generate with: openssl rand -hex 32
NUXT_LOGTO_COOKIE_ENCRYPTION_KEY=

# Public mirror of NUXT_LOGTO_ENDPOINT — used by useAuth() to detect
# whether auth is configured. Should match NUXT_LOGTO_ENDPOINT.
NUXT_PUBLIC_LOGTO_ENDPOINT=

# The API resource (audience) the access token should be bound to.
# Must match the Audience configured in Sabro.API's appsettings
# (Logto:Audience). Example: https://api.sabro.local
NUXT_PUBLIC_SABRO_API_RESOURCE=

# The Sabro API base URL the frontend calls. Defaults to
# http://localhost:5082/api/v1; override for staging/prod.
NUXT_PUBLIC_API_BASE_URL=
