{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": { "Application": "Sabro.API" }
  },
  "ConnectionStrings": {
    "Sabro": ""
  },
  "Logto": {
    "Authority": "",
    "Audience": ""
  },
  "Meilisearch": {
    "Url": "http://localhost:7700",
    "MasterKey": ""
  },
  "AllowedHosts": "*"
}
