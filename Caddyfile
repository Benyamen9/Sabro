# Caddy reverse proxy for the Sabro stack. Caddy provisions and renews TLS
# automatically (Let's Encrypt). Hostnames come from the .env next to
# docker-compose.prod.yml. One reverse_proxy block per public hostname; every
# upstream is a compose service name on the internal network.

{
	email {$CADDY_ACME_EMAIL}
}

# Sabro hub frontend (Nuxt SSR).
{$SABRO_DOMAIN} {
	encode zstd gzip
	reverse_proxy frontend:3000
}

# Sabro API — clients call /api/v1 here directly.
{$SABRO_API_DOMAIN} {
	encode zstd gzip
	reverse_proxy api:8080
}

# Logto — central IDP (OIDC endpoint). Must stay reachable for every app in the
# ecosystem; it is the planned first service to move to its own VM.
{$LOGTO_DOMAIN} {
	reverse_proxy logto:3001
}

# Logto admin console.
{$LOGTO_ADMIN_DOMAIN} {
	reverse_proxy logto:3002
}

# Meltho — Syriac word game (own repo, own container), sharing Sabro's API +
# database behind this same Caddy on its own hostname.
{$MELTHO_DOMAIN} {
	encode zstd gzip
	reverse_proxy meltho:3000
}

# Mno — Syriac numbers game (own repo, own container), sharing Sabro's API +
# database behind this same Caddy on its own hostname.
{$MNO_DOMAIN} {
	encode zstd gzip
	reverse_proxy mno:3000
}

# --- Future ecosystem clients register their own block here -------------------
# Additional clients add one reverse_proxy block per hostname, each pointing at
# their own compose service on the internal network.
