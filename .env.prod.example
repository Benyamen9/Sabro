# Production environment for docker-compose.prod.yml.
# Copy to `.env` on the VPS next to docker-compose.prod.yml and fill in.
# NEVER commit the filled-in .env — it is gitignored.

# --- Container images (GHCR) -------------------------------------------------
# GitHub owner (lowercase) that hosts the images, and the tag to deploy.
# CD overrides SABRO_IMAGE_TAG with the commit SHA.
GHCR_OWNER=benyamen9
SABRO_IMAGE_TAG=latest
# Meltho ships from its own repo + CD, which overrides this with the commit SHA.
MELTHO_IMAGE_TAG=latest

# --- Public hostnames (Caddy provisions TLS for each) ------------------------
SABRO_DOMAIN=sabro.example.com
SABRO_API_DOMAIN=api.sabro.example.com
LOGTO_DOMAIN=auth.sabro.example.com
LOGTO_ADMIN_DOMAIN=auth-admin.sabro.example.com
# Meltho's public hostname, allowed as a CORS origin on the API. Defaults to
# localhost until Meltho is deployed.
MELTHO_DOMAIN=meltho.example.com

# Email Caddy registers with Let's Encrypt for cert notifications.
CADDY_ACME_EMAIL=you@example.com

# --- Shared application database ---------------------------------------------
POSTGRES_DB=sabro
POSTGRES_USER=sabro
POSTGRES_PASSWORD=change-me-strong-password

# --- Logto's own database ----------------------------------------------------
LOGTO_DB_PASSWORD=change-me-strong-password

# --- Meilisearch -------------------------------------------------------------
# Generate: openssl rand -base64 32
MEILI_MASTER_KEY=change-me-meili-master-key

# --- Logto / API identity ----------------------------------------------------
# The API resource (audience) registered in Logto; must match the access
# token's `aud` claim and the frontend's NUXT_PUBLIC_SABRO_API_RESOURCE.
SABRO_API_RESOURCE=https://api.sabro.example.com

# Logto "Traditional Web" app credentials for the Sabro hub frontend.
NUXT_LOGTO_APP_ID=
NUXT_LOGTO_APP_SECRET=
# Session cookie encryption key. Generate: openssl rand -hex 32
NUXT_LOGTO_COOKIE_ENCRYPTION_KEY=

# Logto "Traditional Web" app credentials for the Meltho game — its own OIDC
# app in the same Logto tenant, requesting api:v1:read + api:v1:write only.
MELTHO_LOGTO_APP_ID=
MELTHO_LOGTO_APP_SECRET=
# Separate cookie encryption key from the hub. Generate: openssl rand -hex 32
MELTHO_LOGTO_COOKIE_ENCRYPTION_KEY=
