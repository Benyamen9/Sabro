root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,vue,ts,js,mjs,cjs,html,css,scss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{csproj,props,targets}]
indent_size = 2

[*.cs]
# Modern C# preferences
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_prefer_braces = true:warning
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# StyleCop tweaks
dotnet_diagnostic.SA0001.severity = none   # XML comment analysis disabled
dotnet_diagnostic.SA1633.severity = none   # File header
dotnet_diagnostic.SA1101.severity = none   # Prefix local calls with this
dotnet_diagnostic.SA1200.severity = none   # Using directives placement (handled by stylecop.json)
dotnet_diagnostic.SA1309.severity = none   # Field names should not begin with underscore
dotnet_diagnostic.SA1413.severity = none   # Use trailing comma

# Microsoft analyzers — VB-language compatibility rules don't apply here
dotnet_diagnostic.CA1716.severity = none   # Identifiers conflicting with VB keywords
dotnet_diagnostic.CA1000.severity = none   # Static members on generic types (intentional pattern for Result<T>)
dotnet_diagnostic.CA1305.severity = none   # IFormatProvider on every string operation (noise, especially for logging)
dotnet_diagnostic.CA1304.severity = none   # CultureInfo on string operations
dotnet_diagnostic.CA1310.severity = none   # StringComparison on every string compare

[tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none   # Method_Scenario_Expected naming convention is standard for xUnit tests
dotnet_diagnostic.CA1711.severity = none   # xUnit collection definition classes are conventionally named *Collection

[**/Migrations/**.cs]
generated_code = true
dotnet_diagnostic.IDE0161.severity = none  # File-scoped namespace — EF migrations are tool-generated
dotnet_diagnostic.CA1861.severity = none   # Constant array literals — EF migrations are tool-generated
